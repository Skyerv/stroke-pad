{
  "name": "stroke-pad",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop Hanzi practice sheet generator",
  "main": "frontend/main.js",
  "scripts": {
    "start": "electron ./frontend/main.js",
    "dev": "electron ./frontend/main.js",
    "test": "node --test",
    "build": "electron-builder"
  },
  "dependencies": { },
  "devDependencies": {
    "electron-builder": "^26.8.1",
    "electron": "^37.3.1"
  },
  "build": {
    "appId": "com.strokepad.app",
    "productName": "StrokePad",
    "directories": {
      "buildResources": "frontend/assets"
    },
    "files": [
      "frontend/**/*",
      "backend/data/**/*",
      "package.json",
      "README.md"
    ],
    "win": {
      "target": "nsis",
      "icon": "frontend/assets/icon.png"
    }
  }
}
