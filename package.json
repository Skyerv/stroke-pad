{
  "name": "stroke-pad",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop Hanzi practice sheet generator",
  "main": "frontend/main.js",
  "scripts": {
    "backend": "python -m uvicorn backend.main:app --reload --port 8000",
    "frontend": "electron ./frontend/main.js",
    "start": "electron ./frontend/main.js",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "build": "electron-builder"
  },
  "dependencies": { },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron-builder": "^26.8.1",
    "electron": "^37.3.1"
  },
  "build": {
    "appId": "com.strokepad.app",
    "productName": "StrokePad",
    "directories": {
      "buildResources": "frontend/assets"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "frontend/assets/icon.png"
    }
  }
}
