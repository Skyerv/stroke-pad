{
  "name": "stroke-pad",
  "version": "0.1.0",
  "private": true,
  "description": "Local Electron app for generating Hanzi practice sheets",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "node --test",
    "build": "electron-builder"
  },
  "dependencies": { },
  "devDependencies": {
    "electron-builder": "^26.8.1",
    "electron": "^37.3.1"
  },
  "build": {
    "appId": "com.strokepad.app",
    "productName": "StrokePad",
    "directories": {
      "buildResources": "src/assets"
    },
    "files": [
      "src/**/*",
      "package.json",
      "README.md"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.png"
    }
  }
}
